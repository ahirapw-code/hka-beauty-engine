{
  "version": 2,
  "buildCommand": "npm run build:api && vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/sync-sheets", "schedule": "0 * * * *" },
    { "path": "/api/cron/reset-monthly-sales", "schedule": "0 0 1 * *" }
  ]
}

